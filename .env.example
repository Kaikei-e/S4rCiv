# Non-sensitive configuration. Copy to .env and adjust as needed.
# Sensitive values (the DB password) are provided via Docker secrets, NOT here.
# Create the secret before `docker compose up`:
#   mkdir -p secrets && openssl rand -base64 24 | tr -dc 'A-Za-z0-9' > secrets/db_password.txt

# PostgreSQL (the DB is not published to the host; reached as `db:5432` internally)
POSTGRES_USER=s4rciv
POSTGRES_DB=s4rciv

# Host-published service ports (bound to 127.0.0.1 only). Change if a port is taken.
API_HOST_PORT=8080
WEB_HOST_PORT=3000

# Identifying User-Agent for source collection (see DISCIPLINE.md).
# Real fetching is not enabled yet; scaffolded for when adapters are implemented.
USER_AGENT=s4rCiv-collect/0.1.0 (+mailto:contact@example.org)
